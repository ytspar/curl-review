{
  "name": "curl-review",
  "version": "0.3.3",
  "description": "Safely inspect and optionally execute curl|sh install scripts",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./formatter": {
      "import": "./dist/formatter.js",
      "types": "./dist/formatter.d.ts"
    }
  },
  "bin": {
    "curl-review": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "shell/hook.zsh",
    "shell/hook.bash",
    "shell/hook.fish",
    "shell/shim/curl",
    "setup.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ytspar/curl-review.git"
  },
  "sideEffects": false,
  "license": "MIT"
}
